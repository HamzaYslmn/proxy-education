{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend (vite)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--dir", "frontend", "run", "dev"],
      "port": 5173
    },
    {
      "name": "backend (fastapi proxy)",
      "runtimeExecutable": "uv",
      "runtimeArgs": ["run", "--directory", "backend/src", "uvicorn", "main:app", "--port", "8001"],
      "port": 8001
    }
  ]
}
